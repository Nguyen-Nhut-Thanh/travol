## Public URLs and CORS
API_PUBLIC_URL=https://api.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.com
FRONTEND_PUBLIC_URL=https://your-frontend-domain.com

## Server runtime
HOST=0.0.0.0
PORT=4000

## PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/travel_vn?schema=public

## JWT authentication
JWT_EXPIRES_IN=86400
JWT_SECRET=your_jwt_secret

## Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

## SMTP mail delivery
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Travel V2
MAIL_HOST=smtp.gmail.com
MAIL_INTERNAL_EMAIL=internal@example.com
MAIL_PASS=your_mail_app_password
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@example.com

## Cloudinary media storage
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_SECRET=your_cloudinary_api_secret

## VNPay payment gateway
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_TMN_CODE=your_vnp_tmn_code
